# NOSF config — copy to config.ini and fill in your values.
# After editing: python3 scripts/gen_config.py
# This regenerates firmware/include/tune.h which is compiled into the firmware.
#
# All motor parameters accept a single value (applies to both lanes)
# or a comma-separated list (Lane 1, Lane 2), or a suffixed override. Examples:
#   microsteps: 16              → both lanes use 16
#   microsteps: 16, 32          → Lane 1 = 16, Lane 2 = 32
#   run_current_l1: 0.8         → Lane 1 override (Lane 2 uses global)
#   rotation_distance: 23.0     → both lanes
#   run_current: 0.8, 1.0       → different currents per lane

# ─── Required ────────────────────────────────────────────────────────────────
microsteps:
rotation_distance:
run_current:

# ─── Motor / TMC (per-lane capable) ─────────────────────────────────────────
# full_steps_per_rotation: 200
# gear_ratio: 50:17
# hold_current: 0.980
# dir_invert: 0               # invert motor direction (0/1, comma-list ok)
# interpolate: False
# stealthchop_threshold: 500  # Speed threshold (mm/min) for StealthChop.
#                             # 0 = SpreadCycle always on.
#                             # Non-zero = StealthChop active below this speed.

# ─── TMC Chopper (per-lane capable) ─────────────────────────────────────────
# driver_tbl: 1
# driver_toff: 4
# driver_hstrt: 5
# driver_hend: 3

# ─── Speeds (mm/min) ─────────────────────────────────────────────────────────
# feed_rate: 3000
# rev_rate: 3000
# auto_rate: 3000
# buf_stab_rate: 600         # stabilization speed (boot + UL advance recovery)
# sync_max_rate: 4000
# sync_min_rate: 100
# pre_ramp_rate: 90

# ─── Motion / Ramp ───────────────────────────────────────────────────────────
# motion_startup_ms: 1000
# ramp_step_rate: 17.1
# ramp_tick_ms: 5

# ─── Buffer Sync ─────────────────────────────────────────────────────────────
# buf_hyst_ms: 30
# sync_ramp_up_rate: 40
# sync_ramp_dn_rate: 12
# sync_tick_ms: 20
# baseline_rate: 1600        # starting sync speed (mm/min); set to your print feed rate
# baseline_alpha: 0.02
# buf_predict_thr_ms: 250
# global_max_rate: 4000         # absolute ceiling for every commanded motor rate (mm/min)
# sync_kp_rate: 900
# sync_overshoot_pct: 25         # Trailing-side trim as % of sync correction (0..200)
# sync_reserve_pct: 35           # Reserve target as % of BUF_HALF_TRAVEL toward trailing
# sync_auto_stop_ms: 5000          # Auto-mode only: tail-assist timeout in TRAILING,
                                   # or normal sync timeout only after TRAILING
                                   # recovery has already hit the minimum floor.
# post_print_stab_delay_ms: 0      # Legacy name: idle trailing negative-sync delay.
                                   # 0 = start immediately when idle+TRAILING.
# sync_advance_dwell_stop_ms: 6000 # Hard stop if continuously pinned at advance endstop
                                   # for this many ms. 0 = disable.
# sync_advance_ramp_delay_ms: 400  # Grace window before refill-assist forces target to
                                   # SYNC_MAX regardless of estimator.
# sync_overshoot_mid_extend: 0     # Feature flag: extend trailing overshoot trim into
                                   # BUF_MID when reserve is below deadband. 0=off.

# ─── Phase 2.5 — Integral Centering + Estimator Confidence ───────────────────
# sync_reserve_integral_gain: 0.0  # I-gain (mm of target bias per mm·s of reserve error).
                                   # 0.0 = feature disabled (default, behavior-identical to
                                   # Phase 2). Enable with a small value (e.g. 0.005) after
                                   # reviewing soak-run data.
# sync_reserve_integral_clamp_mm: 0.6  # Hard clamp on the integral correction in mm.
                                       # Cannot exceed buf_virtual_deadband_mm() in practice.
# sync_reserve_integral_decay_ms: 0    # Reserved for future use; 0 = hold integral while frozen.
# est_sigma_hard_cap_mm: 1.5           # Confidence drops to 0 when estimator sigma reaches this.
                                       # Approximates physical buffer half-travel.
# est_low_cf_warn_threshold: 0.5       # EV:BUF,EST_LOW_CF fires when confidence < this.
# est_fallback_cf_threshold: 0.2       # Integral freezes when confidence < this.

# ─── Phase 2.6 — Drift Observer & ADVANCE-Risk Telemetry ─────────────────────
# buf_drift_ewma_tau_ms: 60000        # EWMA time constant for per-transition residual drift (ms).
#                                     # Longer = more stable estimate; shorter = faster adaptation.
# buf_drift_min_samples: 3            # Samples before full correction; enabled correction ramps in earlier.
# buf_drift_apply_thr_mm: 2.0         # Provisional correction threshold in mm; 0.0 disables correction.
#                                     # Raise/lower after observing stable BPD convergence in real prints.
# buf_drift_clamp_mm: 3.0             # Provisional hard clamp on applied correction magnitude in mm (runtime max 8.0).
# buf_drift_apply_min_cf: 0.5         # Min estimator confidence (EC:/100) required to apply correction.
# adv_risk_window_ms: 60000           # Rolling window for ADVANCE-pin density warning (runtime-only).
# adv_risk_threshold: 4               # EV:SYNC,ADV_RISK_HIGH fires when pin count >= this (runtime-only).

# ─── Smarter Sync (Estimator) ────────────────────────────────────────────────
# est_alpha_min: 0.12          # Estimator responsiveness (slow drifts)
# est_alpha_max: 0.65          # Estimator responsiveness (sharp jumps)
# zone_bias_base_rate: 90      # Base reserve-recovery correction (mm/min)
# zone_bias_ramp_rate: 30      # Reserve-recovery ramp (mm/min per second stuck in zone)
# zone_bias_max_rate: 600      # Max reserve-recovery correction (mm/min)
# reload_lean_factor: 0.85     # RELOAD follow under-feed factor (0.0 to 1.0)

# ─── Cutter / Servo ──────────────────────────────────────────────────────────
# servo_open_us: 500
# servo_close_us: 1400
# servo_block_us: 950
# servo_settle_ms: 500
# cut_feed_mm: 48
# cut_length_mm: 10
# cut_amount: 1

# ─── Toolchange Timeouts ─────────────────────────────────────────────────────
# tc_timeout_cut_ms: 5000
# tc_timeout_th_ms: 3000
# tc_timeout_y_ms: 5000

# ─── Safety / Limits ─────────────────────────────────────────────────────────
# load_max_mm: 3000           # Max distance for toolhead load
# unload_max_mm: 3000         # Max distance for unloads
# autoload_max_mm: 600        # Max distance for preload to OUT
# runout_cooldown_ms: 12000

# ─── Flow Control ────────────────────────────────────────────────────────────
# auto_mode: True             # Enable automated flow (auto-sync, toolhead load)
# auto_preload: True          # Enable parking preload on insertion

# ─── Physical Model (mm) ─────────────────────────────────────────────────────
# dist_in_out: 150            # Distance between IN and OUT sensors
# dist_out_y: 100             # Distance from OUT sensor to Y-splitter
# dist_y_buf: 300             # Distance from Y-splitter to buffer entry
# buf_body_len: 200           # Total physical length of buffer body
# buf_half_travel_mm: 7.8     # Distance from MID to switch trip, not total half-travel
# buf_size_mm: 22             # Total travel distance of buffer arm

# ─── Analog Buffer Sensor ─────────────────────────────────────────────────────
# buf_sensor_type: 0
# buf_neutral: 0.5
# buf_range: 0.45
# buf_thr: 0.30
# buf_analog_alpha: 0.20

# ─── TS Fallback ─────────────────────────────────────────────────────────────
# ts_buf_fallback_ms: 2000

# ─── Reload Mode ─────────────────────────────────────────────────────────────
# reload_mode: 1              # Enable autonomous swap on runout
# reload_y_timeout_ms: 10000  # max wait for Y to clear during RELOAD
# reload_join_delay_ms: 10000 # extra wait after tail/Y clear before JOINING

# ─── RELOAD Tuning ───────────────────────────────────────────────────────────
# trailing_rate: 90           # coasting speed when buffer is stalled
# join_rate: 1600             # fast approach speed
# press_rate: 1200            # top speed in follow-sync
# reload_touch_settle_ms: 120 # brief settle after tail-to-tip touch
# reload_touch_boost_ms: 900  # boosted push window after settle
# reload_touch_floor_pct: 90  # min % of PRESS_RATE during boost window
# follow_timeout_ms: 10000    # max time in follow before error
