# NOSF config — copy to config.ini and fill in your values.
# After editing: python3 scripts/gen_config.py
# This regenerates firmware/include/tune.h which is compiled into the firmware.
#
# All motor parameters accept a single value (applies to both lanes)
# or a comma-separated list (Lane 1, Lane 2), or a suffixed override. Examples:
#   microsteps: 16              → both lanes use 16
#   microsteps: 16, 32          → Lane 1 = 16, Lane 2 = 32
#   run_current_l1: 0.8         → Lane 1 override (Lane 2 uses global)
#   rotation_distance: 23.0     → both lanes
#   run_current: 0.8, 1.0       → different currents per lane

# ─── Required ────────────────────────────────────────────────────────────────
microsteps:
rotation_distance:
run_current:

# ─── Motor / TMC (per-lane capable) ─────────────────────────────────────────
# full_steps_per_rotation: 200
# gear_ratio: 1:1
# hold_current:               # defaults to run_current / 2 if omitted
# dir_invert: 0               # invert motor direction (0/1, comma-list ok)
# interpolate: True
# stealthchop_threshold: 0    # 0 = SpreadCycle always on (recommended for MMU)

# ─── TMC Chopper (per-lane capable) ─────────────────────────────────────────
# driver_tbl: 2
# driver_toff: 3
# driver_hstrt: 5
# driver_hend: 0

# ─── StallGuard / CoolStep (per-lane capable) ────────────────────────────────
# sgthrs: 0                   # StallGuard threshold (0 to 255; 255 = most sensitive)
# tcoolthrs: 0xFFFFF          # SG activation threshold (TSTEP); 0xFFFFF = always active
# sg_current_ma: 800          # current when SG is active (RELOAD or SYNC_SG=1)


# ─── Speeds (mm/min) ─────────────────────────────────────────────────────────
# feed_rate: 2100
# rev_rate: 2100
# auto_rate: 2100
# sync_max_rate: 2500
# sync_min_rate: 0
# pre_ramp_rate: 35

# ─── Motion / Ramp ───────────────────────────────────────────────────────────
# motion_startup_ms: 1000
# ramp_step_rate: 17
# ramp_tick_ms: 5
# stall_recovery_ms: 3000

# ─── Buffer Sync ─────────────────────────────────────────────────────────────
# buf_hyst_ms: 30
# sync_ramp_up_rate: 25
# sync_ramp_dn_rate: 13
# sync_tick_ms: 20
# baseline_rate: 2100        # starting sync speed (mm/min); set to your print feed rate
# baseline_alpha: 0.15
# buf_predict_thr_ms: 250
# sync_kp_rate: 850

# ─── Cutter / Servo ──────────────────────────────────────────────────────────
# servo_open_us: 500
# servo_close_us: 1400
# servo_block_us: 950
# servo_settle_ms: 500
# cut_feed_mm: 48
# cut_length_mm: 10
# cut_amount: 1

# ─── Toolchange Timeouts ─────────────────────────────────────────────────────
# tc_timeout_cut_ms: 5000
# tc_timeout_th_ms: 3000
# tc_timeout_y_ms: 5000

# ─── Safety / Limits ─────────────────────────────────────────────────────────
# load_max_mm: 3000           # Max distance for toolhead load
# unload_max_mm: 3000         # Max distance for unloads
# autoload_max_mm: 600        # Max distance for preload to OUT
# swap_cooldown_ms: 500
# runout_cooldown_ms: 12000

# ─── Flow Control ────────────────────────────────────────────────────────────
# auto_mode: True             # Enable automated flow (auto-sync, toolhead load)
# auto_preload: True          # Enable parking preload on insertion

# ─── Physical Model (mm) ─────────────────────────────────────────────────────
# dist_in_out: 150            # Distance between IN and OUT sensors
# dist_out_y: 100             # Distance from OUT sensor to Y-splitter
# dist_y_buf: 300             # Distance from Y-splitter to buffer entry
# buf_body_len: 200           # Total physical length of buffer body
# buf_size_mm: 50             # Total travel distance of buffer arm

# ─── Analog Buffer Sensor ─────────────────────────────────────────────────────
# buf_sensor_type: 0
# buf_neutral: 0.5
# buf_range: 0.45
# buf_thr: 0.30
# buf_analog_alpha: 0.20

# ─── TS Fallback ─────────────────────────────────────────────────────────────
# ts_buf_fallback_ms: 2000

# ─── Reload Mode ─────────────────────────────────────────────────────────────
# reload_mode: 0              # Enable autonomous swap on runout
# reload_y_timeout_ms: 10000  # max wait for Y to clear during RELOAD

# ─── RELOAD StallGuard Tuning (per-lane capable) ──────────────────────────────
# sg_target: 320.0            # target SG value for follow-sync
# sg_deriv: 3                 # approach contact threshold
# trailing_rate: 42           # coasting speed when buffer is stalled
# join_rate: 2100             # fast approach speed
# press_rate: 1275            # top speed in follow-sync
# follow_timeout_ms: 10000    # max time in follow before error
# sync_sg_interp: False       # SG interpolation during normal sync
# reload_sg_interp: True      # SG interpolation during RELOAD follow
