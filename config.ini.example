# NOSF config - copy this file to config.ini and fill in your values.
# Section headers are optional and ignored; all keys are read regardless of section.
# After editing run: python3 scripts/gen_motor_config.py
# This regenerates firmware/include/tune.h which is compiled into the firmware.

# --- Required ---
microsteps:
rotation_distance:
run_current:

# --- ISS StallGuard Tuning ---
# iss_sg_target: 320             # target SG value for follow-sync (G36HSY4405-6D-1200 @ 800mA)
# iss_sg_deriv_thr: 0            # derivative threshold for approach contact (0 = disabled)
# iss_current_ma: 800            # high-torque current for ISS/Sync tasks
# iss_trailing_sps: 500          # coasting speed when buffer is stalled (trailing)
# iss_join_sps: 25000            # fast approach speed
# iss_press_sps: 15000           # top speed in follow-sync
# iss_follow_timeout_ms: 10000   # max time in trailing before error

# --- Optional (Klipper defaults shown) ---
# full_steps_per_rotation: 200
# gear_ratio: 1:1
# hold_current:                  # defaults to run_current / 2 if omitted
# sense_resistor: 0.110
# interpolate: True
# driver_TBL: 2
# driver_TOFF: 3
# driver_HSTRT: 5
# driver_HEND: 0
# stealthchop_threshold: 0       # 0 = SpreadCycle always on (recommended for MMU)
